# Django configuration variables for production
# Copy this file to .env and fill in the values, or set them in your hosting environment settings.

# SECURITY WARNING: Keep this secret in production! Generate a long random string.
DJANGO_SECRET_KEY=your_secure_production_secret_key_here

# Turn off debug mode in production (set to False)
DJANGO_DEBUG=False

# Comma-separated list of hosts allowed to access your app
# E.g., DJANGO_ALLOWED_HOSTS=spellbound.onrender.com,spellboundedit.com
DJANGO_ALLOWED_HOSTS=yourdomain.com,your-app-name.herokuapp.com,localhost
